---
import HeadMeta from '../components/head/HeadMeta.astro';
import CursorDot from '../components/slide/CursorDot.astro';
import Slide from '../components/slide/Slide.astro';
import { parseDeck, parseFrame, parseTitle } from '../lib/parser';
import type { DeckSource } from '../lib/types';
import 'virtual:uno.css';
import '../styles/theme.css';
import '../styles/slide-common.css';
import '../styles/deck.css';

// Load every `benben/**/*.md` as raw text at build time. Vite wires HMR so
// editing any deck file hot-reloads the matching route. Nested directories
// are allowed: `benben/sub/foo.md` → `/sub/foo`. (`benben` = the primordial
// mound that rose from Nun — i.e. what the Nun renderer draws from.)
export async function getStaticPaths() {
  const files = import.meta.glob('../../benben/**/*.md', {
    query: '?raw',
    import: 'default',
    eager: true,
  }) as Record<string, string>;
  return Object.entries(files).map(([path, raw]) => {
    const name = path
      .replace(/\\/g, '/')
      .replace(/^.*\/benben\//, '')
      .replace(/\.md$/, '');
    return { params: { deck: name }, props: { parsed: parseDeck(raw) } };
  });
}

interface Props {
  parsed: DeckSource;
}

const { parsed: deck } = Astro.props;
const { deck: name } = Astro.params;
const titleSource = deck.slides.find((s) => s.template === 'title') ?? deck.slides[0];
const ogTitle = titleSource?.heading ?? name;
const subtitle = titleSource ? (parseTitle(parseFrame(titleSource, 0)).subtitle ?? '') : '';
const ogDesc = [subtitle && `${subtitle} by へのへのん`, deck.globalMeta.date].filter(Boolean).join(' ');
const base = import.meta.env.BASE_URL;
const ogUrl = new URL(`${base}${name}`, Astro.site).href;
const thumbUrl = new URL(`${base}thumbs/${name}.webp`, Astro.site).href;
---

<html lang="ja">
  <head>
    <HeadMeta
      title={`${ogTitle} — へのへ Nun`}
      description={ogDesc}
      ogTitle={ogTitle}
      ogImage={thumbUrl}
      ogUrl={ogUrl}
    />
    <meta name="view-transition" content="same-document" />
  </head>
  <body>
    <div class="stage">
      <div class="canvas" id="canvas">
        {deck.slides.map((source, i) => <Slide source={source} index={i} globalMeta={deck.globalMeta} />)}
      </div>
    </div>

    <CursorDot />

    <script>
      const canvas = document.getElementById('canvas')!;
      const slides = Array.from(canvas.querySelectorAll<HTMLElement>('.slide'));
      const total = slides.length;

      function currentIndex(): number {
        const hash = location.hash.replace('#', '');
        const n = parseInt(hash, 10);
        if (!Number.isFinite(n)) return 0;
        return Math.max(0, Math.min(total - 1, n));
      }

      function show(i: number) {
        const apply = () => {
          slides.forEach((s, idx) => {
            s.style.visibility = idx === i ? 'visible' : 'hidden';
          });
        };
        if (document.startViewTransition) {
          document.startViewTransition(apply);
        } else {
          apply();
        }
      }

      function go(delta: number) {
        const next = Math.max(0, Math.min(total - 1, currentIndex() + delta));
        location.hash = String(next);
      }

      function toggleFullscreen() {
        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else {
          document.documentElement.requestFullscreen().catch(() => {});
        }
      }

      window.addEventListener('hashchange', () => show(currentIndex()));
      window.addEventListener('keydown', (e) => {
        const k = e.key.toLowerCase();
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ' || e.key === 'PageDown' || k === 'd' || k === 's') {
          e.preventDefault();
          go(1);
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp' || e.key === 'PageUp' || k === 'a' || k === 'w') {
          e.preventDefault();
          go(-1);
        } else if (e.key === 'Home') {
          location.hash = '0';
        } else if (e.key === 'End') {
          location.hash = String(total - 1);
        } else if (e.key === 'Enter') {
          e.preventDefault();
          toggleFullscreen();
        }
      });
      window.addEventListener('click', (e) => {
        if (!document.fullscreenElement) return;
        if ((e.target as HTMLElement).closest('a')) return;
        const x = e.clientX;
        if (x < window.innerWidth / 2) go(-1);
        else go(1);
      });

      let wheelLock = 0;
      window.addEventListener('wheel', (e) => {
        const d = e.deltaY || e.deltaX;
        if (Math.abs(d) < 10) return;
        const now = Date.now();
        if (now < wheelLock) return;
        wheelLock = now + 400;
        go(d > 0 ? 1 : -1);
      }, { passive: true });

      // Swipe navigation (touch devices).
      let touchStartX = 0;
      let touchStartY = 0;
      window.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
      }, { passive: true });
      window.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].clientX - touchStartX;
        const dy = e.changedTouches[0].clientY - touchStartY;
        if (Math.abs(dx) < 50 || Math.abs(dx) < Math.abs(dy)) return;
        go(dx < 0 ? 1 : -1);
      });

      // Auto-fit: shrink slide-body via zoom when content overflows.
      // Temporarily show each slide for measurement, then restore visibility.
      slides.forEach((s) => {
        const prev = s.style.visibility;
        s.style.visibility = 'visible';
        s.querySelectorAll<HTMLElement>('.slide-body').forEach((body) => {
          const sx = body.scrollWidth > body.clientWidth ? body.clientWidth / body.scrollWidth : 1;
          const sy = body.scrollHeight > body.clientHeight ? body.clientHeight / body.scrollHeight : 1;
          const scale = Math.min(sx, sy);
          if (scale < 1) {
            body.style.zoom = String(Math.max(scale, 0.1));
          }
        });
        s.style.visibility = prev;
      });
      show(currentIndex());
    </script>

  </body>
</html>
