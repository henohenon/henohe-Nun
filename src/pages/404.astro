---
import HeadMeta from '../components/HeadMeta.astro';
import '../styles/theme.css';
---

<html lang="ja">
  <head>
    <HeadMeta title="404 — へのへ Nun" />
  </head>
  <body>
    <main>
      <h1>404</h1>
      <p>Page was Nun found.</p>
      <a href={import.meta.env.BASE_URL}>Back to top</a>
    </main>

    <style>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: #ffffff;
      }
      main {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        font-family: 'IBM Plex Sans JP', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Hiragino Kaku Gothic ProN', 'Yu Gothic', 'Meiryo', sans-serif;
        color: #0a0a0a;
      }
      h1 {
        font-size: 96px;
        font-weight: 900;
        margin: 0;
        color: var(--theme-color);
      }
      p {
        font-size: 18px;
        margin: 12px 0 24px;
        color: #888;
      }
      a {
        color: var(--theme-color);
        text-decoration: none;
        font-weight: 600;
      }
      a:hover {
        text-decoration: underline;
      }
    </style>
  </body>
</html>
