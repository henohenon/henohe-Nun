---
import Favicon from '../components/Favicon.astro';
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 — へのへ Nun</title>
    <Favicon />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+JP:wght@100;200;300;400;500;600;700&display=swap" />
  </head>
  <body>
    <main>
      <h1>404</h1>
      <p>Page was Nun found.</p>
      <a href={import.meta.env.BASE_URL}>Back to top</a>
    </main>

    <style>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: #ffffff;
      }
      main {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        font-family: 'IBM Plex Sans JP', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: #0a0a0a;
      }
      h1 {
        font-size: 96px;
        font-weight: 900;
        margin: 0;
        color: #5932FF;
      }
      p {
        font-size: 18px;
        margin: 12px 0 24px;
        color: #888;
      }
      a {
        color: #5932FF;
        text-decoration: none;
        font-weight: 600;
      }
      a:hover {
        text-decoration: underline;
      }
    </style>
  </body>
</html>
