---
import { parseDeck } from '../lib/parser';
import Slide from '../components/Slide.astro';
import '../styles/slide-common.css';

// Load every `benben/*.md` as raw text at build time. Vite wires HMR so
// editing any deck file hot-reloads the matching route. (`benben` = the
// primordial mound that rose from Nun — i.e. what the Nun renderer draws from.)
export async function getStaticPaths() {
  const files = import.meta.glob('../../benben/*.md', {
    query: '?raw',
    import: 'default',
    eager: true,
  }) as Record<string, string>;
  return Object.entries(files).map(([path, raw]) => {
    const name = path.split('/').pop()!.replace(/\.md$/, '');
    return { params: { deck: name }, props: { raw } };
  });
}

interface Props {
  raw: string;
}

const { raw } = Astro.props;
const { deck: deckName } = Astro.params;
const deck = parseDeck(raw);
const titleSlide = deck.slides.find((s) => s.template === 'title') ?? deck.slides[0];
const ogTitle = titleSlide?.heading ?? deckName;
const thumbUrl = `/thumbs/${deckName}.webp`;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{deckName} — へのへ Nun</title>
    <meta property="og:title" content={ogTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={thumbUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:image" content={thumbUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+JP:wght@100;200;300;400;500;600;700&display=swap" />
  </head>
  <body>
    <div class="stage">
      <div class="canvas" id="canvas">
        {deck.slides.map((slide) => <Slide slide={slide} date={deck.date} />)}
      </div>
    </div>

    <div class="cursor-dot" id="cursor-dot"></div>

    <div class="hint" id="hint">
      Press <kbd>Enter</kbd> to toggle fullscreen
    </div>

    <script>
      const canvas = document.getElementById('canvas')!;
      const slides = Array.from(canvas.querySelectorAll<HTMLElement>('.slide'));
      const total = slides.length;
      const hint = document.getElementById('hint')!;

      let hintDismissed = false;
      function dismissHint() {
        if (hintDismissed) return;
        hintDismissed = true;
        hint.classList.add('hidden');
      }
      setTimeout(dismissHint, 4000);

      function currentIndex(): number {
        const hash = location.hash.replace('#', '');
        const n = parseInt(hash, 10);
        if (!Number.isFinite(n)) return 0;
        return Math.max(0, Math.min(total - 1, n));
      }

      function show(i: number) {
        slides.forEach((s, idx) => {
          s.style.visibility = idx === i ? 'visible' : 'hidden';
        });
      }

      function go(delta: number) {
        const next = Math.max(0, Math.min(total - 1, currentIndex() + delta));
        location.hash = String(next);
      }

      function toggleFullscreen() {
        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else {
          document.documentElement.requestFullscreen().catch(() => {});
        }
      }

      const dot = document.getElementById('cursor-dot')!;

      document.addEventListener('fullscreenchange', () => {
        const fs = !!document.fullscreenElement;
        document.body.classList.toggle('is-fullscreen', fs);
        dot.style.display = fs ? 'block' : 'none';
      });

      window.addEventListener('mousemove', (e) => {
        dot.style.left = `${e.clientX}px`;
        dot.style.top = `${e.clientY}px`;
      });

      window.addEventListener('hashchange', () => show(currentIndex()));
      window.addEventListener('keydown', (e) => {
        dismissHint();
        const k = e.key.toLowerCase();
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ' || e.key === 'PageDown' || k === 'd' || k === 's') {
          e.preventDefault();
          go(1);
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp' || e.key === 'PageUp' || k === 'a' || k === 'w') {
          e.preventDefault();
          go(-1);
        } else if (e.key === 'Home') {
          location.hash = '0';
        } else if (e.key === 'End') {
          location.hash = String(total - 1);
        } else if (e.key === 'Enter') {
          e.preventDefault();
          toggleFullscreen();
        }
      });
      window.addEventListener('click', (e) => {
        if (!document.fullscreenElement) return;
        dismissHint();
        const x = e.clientX;
        if (x < window.innerWidth / 2) go(-1);
        else go(1);
      });

      let wheelLock = 0;
      window.addEventListener('wheel', (e) => {
        const d = e.deltaY || e.deltaX;
        if (Math.abs(d) < 10) return;
        const now = Date.now();
        if (now < wheelLock) return;
        wheelLock = now + 400;
        dismissHint();
        go(d > 0 ? 1 : -1);
      }, { passive: true });

      // Auto-fit: elements with data-fit get zoom to fit within .slide-body.
      slides.forEach((s) => (s.style.visibility = 'visible'));
      document.querySelectorAll<HTMLElement>('[data-fit]').forEach((el) => {
        const parent = el.parentElement;
        if (!parent) return;
        const origOverflow = parent.style.overflow;
        parent.style.overflow = 'hidden';
        const availH = parent.clientHeight;
        const availW = parent.clientWidth;
        parent.style.overflow = origOverflow;
        const eh = el.scrollHeight;
        const ew = el.scrollWidth;
        const mode = el.dataset.fit;
        let scale = 1;
        if (mode === 'v' && eh > availH) scale = availH / eh;
        else if (mode === 'h' && ew > availW) scale = availW / ew;
        else if (mode === 'both') {
          const sx = ew > availW ? availW / ew : 1;
          const sy = eh > availH ? availH / eh : 1;
          scale = Math.min(sx, sy);
        }
        if (scale < 1) el.style.zoom = String(Math.max(scale, 0.2));
      });
      show(currentIndex());
    </script>

    <style is:global>
      :root {
        --theme-color: #5932FF;
      }
      /* All bold text inside slides uses the theme color. */
      .slide strong,
      .slide b,
      .slide h1,
      .slide h2,
      .slide h3 {
        color: var(--theme-color);
      }
      html, body {
        margin: 0;
        padding: 0;
        background: #ffffff;
        height: 100%;
        overflow: hidden;
      }
      body.is-fullscreen astro-dev-toolbar {
        display: none !important;
      }
      .stage {
        position: fixed;
        inset: 0;
      }
      .canvas {
        position: absolute;
        inset: 0;
      }
      .hint {
        position: fixed;
        left: 50%;
        bottom: 40px;
        transform: translateX(-50%);
        padding: 12px 24px;
        background: rgba(10, 10, 10, 0.82);
        color: #fafafa;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        font-size: 15px;
        border-radius: 999px;
        pointer-events: none;
        opacity: 1;
        transition: opacity 0.4s ease;
        z-index: 100;
      }
      .hint.hidden {
        opacity: 0;
      }
      body.is-fullscreen {
        cursor: none;
      }
      .cursor-dot {
        display: none;
        position: fixed;
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: var(--theme-color);
        opacity: 0.75;
        pointer-events: none;
        transform: translate(-50%, -50%);
        z-index: 99;
        transition: left 0.08s ease-out, top 0.08s ease-out;
      }
      .hint kbd {
        display: inline-block;
        padding: 2px 8px;
        margin: 0 2px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 4px;
        font-family: inherit;
        font-weight: 600;
      }

      /* PDF export: Playwright's page.pdf() uses print media. Unstack the
         visibility-toggled slides into one page each at a fixed 1920x1080
         box so cqmin/cqw/cqh-based clamp()s resolve identically to screen. */
      @media print {
        @page {
          size: 1920px 1080px;
          margin: 0;
        }
        html, body {
          overflow: visible !important;
          height: auto !important;
          background: #fff !important;
        }
        .hint { display: none !important; }
        .stage, .canvas {
          position: static !important;
          inset: auto !important;
        }
        .slide {
          position: relative !important;
          visibility: visible !important;
          width: 1920px !important;
          height: 1080px !important;
          break-after: page;
          page-break-after: always;
        }
        .slide:last-child {
          break-after: auto;
          page-break-after: auto;
        }
      }
    </style>
  </body>
</html>
