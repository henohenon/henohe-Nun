---
import HeadMeta from '../components/head/HeadMeta.astro';
import { parseDeck } from '../lib/parser';
import '../styles/theme.css';

const files = import.meta.glob('../../benben/*.md', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const decks = Object.entries(files)
  .map(([path, raw]) => {
    const name = path.split('/').pop()?.replace(/\.md$/, '');
    const deck = parseDeck(raw);
    const titleSlide = deck.slides.find((s) => s.template === 'title') ?? deck.slides[0];
    return {
      name,
      title: titleSlide?.heading ?? name,
      date: deck.date ?? null,
    };
  })
  .sort((a, b) => (b.date ?? '').localeCompare(a.date ?? ''));
const base = import.meta.env.BASE_URL;
---

<html lang="ja">
  <head>
    <HeadMeta title="へのへ Nun" />
  </head>
  <body>
    <main class="index">
      <h1>へのへ Nun</h1>
      {decks.length === 0 ? (
        <p class="empty">No decks found in <code>benben/</code>.</p>
      ) : (
        <ul class="decks">
          {decks.map((d) => (
            <li>
              <a href={`${base}${d.name}#0`}>
                <div class="thumb">
                  <img src={`${base}thumbs/${d.name}.webp`} alt={d.title} />
                </div>
                <div class="info">
                  <span class="title">{d.title}</span>
                  {d.date && <span class="date">{d.date}</span>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>

    <style>
      :global(html), :global(body) {
        margin: 0;
        padding: 0;
        background: #ffffff;
        min-height: 100%;
      }
      .index {
        max-width: 800px;
        margin: 0 auto;
        padding: 64px 32px;
        font-family: var(--font-body);
        color: #0a0a0a;
      }
      h1 {
        font-size: 32px;
        margin: 0 0 32px;
      }
      .decks {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 20px;
      }
      .decks a {
        display: flex;
        align-items: center;
        gap: 20px;
        text-decoration: none;
        color: inherit;
        padding: 12px;
        border-radius: 10px;
        transition: background 0.15s;
      }
      .decks a:hover {
        background: #f5f5f5;
      }
      .thumb {
        width: 240px;
        aspect-ratio: 1200 / 630;
        overflow: hidden;
        border-radius: 6px;
        border: 1px solid #e0e0e0;
        flex-shrink: 0;
      }
      .thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .info {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 0;
      }
      .title {
        font-size: 20px;
        font-weight: 700;
        color: #0a0a0a;
      }
      .date {
        font-size: 14px;
        color: #888;
      }
      .empty {
        color: #888;
      }
      code {
        background: #f3f3f3;
        padding: 2px 6px;
        border-radius: 4px;
      }
    </style>
  </body>
</html>
