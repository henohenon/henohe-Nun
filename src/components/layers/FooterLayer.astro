---
import { Image } from 'astro:assets';
import { marked } from 'marked';
import type { FooterText, AssetRef } from '../../lib/parser';
import { imgAttrStyle } from '../../lib/parser';
import { resolveImage } from '../../lib/images';

interface Props {
  fl?: FooterText;
  fr?: FooterText;
  fbg?: AssetRef;
  slideIndex: number;
}

const { fl, fr, fbg, slideIndex } = Astro.props;

const flHtml = fl?.text ? (marked.parseInline(fl.text) as string) : '';
const frHtml = fr?.text ? (marked.parseInline(fr.text) as string) : '';
const hasFooter = !!(flHtml || frHtml);

function htmlToSvgText(html: string): string {
  return html
    .replace(/<strong>(.*?)<\/strong>/g, '<tspan font-weight="900">$1</tspan>')
    .replace(/<b>(.*?)<\/b>/g, '<tspan font-weight="900">$1</tspan>')
    .replace(/<del>(.*?)<\/del>/g, '<tspan text-decoration="line-through">$1</tspan>')
    .replace(/<em>(.*?)<\/em>/g, '<tspan font-style="italic">$1</tspan>')
    .replace(/<[^>]+>/g, '');
}

const flSvg = htmlToSvgText(flHtml);
const frSvg = htmlToSvgText(frHtml);
const maskId = `footer-mask-${slideIndex}`;

const hasFbg = hasFooter && !!fbg;
const fbgImgStyle = hasFbg ? imgAttrStyle(fbg!) : '';
const fbgImage = hasFbg ? resolveImage(fbg!.src) : undefined;
const fbgBlurPx = fbg?.attrs.blur ? Number(fbg.attrs.blur) : 0;
---

{hasFooter && (
  <svg class="slide-footer-svg" xmlns="http://www.w3.org/2000/svg">
    {hasFbg && (
      <defs>
        <mask id={maskId}>
          <g style={fbgBlurPx > 0 ? `transform:translate(${fbgBlurPx}px,${fbgBlurPx}px)` : undefined}>
            <rect class="footer-svg-line" fill="white" />
            {flSvg && <text class="footer-svg-fl" fill="white" set:html={flSvg} />}
            {frSvg && <text class="footer-svg-fr" fill="white" set:html={frSvg} />}
          </g>
        </mask>
      </defs>
    )}
    <rect class="footer-svg-line" fill="black" />
    {flSvg && <text class="footer-svg-fl" fill="black" set:html={flSvg} />}
    {frSvg && <text class="footer-svg-fr" fill="black" set:html={frSvg} />}
  </svg>
)}
{hasFbg && fbgImage && (
  <Image
    class="slide-fbg"
    src={fbgImage}
    alt=""
    widths={[1920]}
    loading="eager"
    style={`${fbgImgStyle};--blur-expand:${fbgBlurPx}px;-webkit-mask:url(#${maskId});mask:url(#${maskId})`}
  />
)}
{hasFbg && !fbgImage && (
  <img
    class="slide-fbg"
    src={fbg!.src}
    alt=""
    style={`${fbgImgStyle};--blur-expand:${fbgBlurPx}px;-webkit-mask:url(#${maskId});mask:url(#${maskId})`}
  />
)}

<style>
  .slide-footer-svg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: visible;
    z-index: 1;
  }
  .footer-svg-line {
    x: -1px;
    width: calc(100cqw + 2px);
    y: calc(100cqh - var(--footer-line-height) - 1px);
    height: calc(var(--footer-line-height) + 3px);
  }
  .footer-svg-fl,
  .footer-svg-fr {
    font-family: 'IBM Plex Sans JP', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Hiragino Kaku Gothic ProN', 'Yu Gothic', 'Meiryo', sans-serif;
    font-size: var(--footer-font-size);
    font-weight: 700;
    dominant-baseline: text-after-edge;
  }
  .footer-svg-fl {
    text-anchor: start;
    transform: translate(var(--footer-pad-x), calc(100cqh - var(--footer-line-height) - var(--footer-text-nudge)));
  }
  .footer-svg-fr {
    text-anchor: end;
    transform: translate(calc(100cqw - var(--footer-pad-x)), calc(100cqh - var(--footer-line-height) - var(--footer-text-nudge)));
  }
  .slide-fbg {
    position: absolute;
    inset: calc(-1 * var(--blur-expand));
    max-width: calc(100% + 2 * var(--blur-expand));
    max-height: calc(100% + 2 * var(--blur-expand));
    object-fit: cover;
    pointer-events: none;
    z-index: 2;
  }
</style>
