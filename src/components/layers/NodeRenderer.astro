---
import { getImage } from 'astro:assets';
import hljs from 'highlight.js';
import { Marked } from 'marked';
import { markedHighlight } from 'marked-highlight';
import { resolveImage } from '../../lib/images';
import type { Attrs, Node } from '../../lib/parser';
import { attrsToStyle, rewriteAssetPath } from '../../lib/parser';

interface Props {
  nodes: Node[];
}

const { nodes } = Astro.props;

// Collect all image paths from markdown nodes, resolve via Astro image pipeline.
const IMAGE_EXT = /\.(png|jpe?g|svg|gif|webp|avif)$/i;

function collectImagePaths(nodeList: Node[]): string[] {
  const paths: string[] = [];
  for (const n of nodeList) {
    if (n.kind === 'markdown') {
      const re = /(?<!!)\[([^\]]+)\](?!\()/g;
      let m: RegExpExecArray | null;
      while ((m = re.exec(n.text)) !== null) {
        const trimmed = m[1].trim();
        if (IMAGE_EXT.test(trimmed)) paths.push(rewriteAssetPath(trimmed));
      }
    } else if ('children' in n) {
      paths.push(...collectImagePaths(n.children));
    }
  }
  return paths;
}

const imagePaths = [...new Set(collectImagePaths(nodes))];
const optimizedMap = new Map<string, string>();

for (const p of imagePaths) {
  const meta = resolveImage(p);
  if (meta) {
    const result = await getImage({ src: meta, width: 1920 });
    optimizedMap.set(p, result.src);
  }
}

const marked = new Marked(
  { gfm: true, breaks: false },
  markedHighlight({
    langPrefix: 'hljs language-',
    highlight(code, lang) {
      if (lang && hljs.getLanguage(lang)) {
        return hljs.highlight(code, { language: lang }).value;
      }
      return hljs.highlightAuto(code).value;
    },
  }),
);

// Pre-process markdown text before passing to marked:
// - [path.png] → ![](optimized_path) (image embed)
// - [url] → [url](url) (auto-link)
function preprocessMd(text: string): string {
  return text.replace(/(?<!!)\[([^\]]+)\](?!\()/g, (_, content: string) => {
    const trimmed = content.trim();
    if (IMAGE_EXT.test(trimmed)) {
      const rewritten = rewriteAssetPath(trimmed);
      const optimized = optimizedMap.get(rewritten) ?? rewritten;
      return `![](${optimized})`;
    }
    if (/^https?:\/\//.test(trimmed)) {
      return `[${trimmed}](${trimmed})`;
    }
    return `[${content}]`;
  });
}

function addCodeChrome(html: string): string {
  return html
    .replace(
      /<pre><code class="hljs language-(\w+)">/g,
      (_, lang) =>
        `<div class="code-block"><div class="code-header"><span class="code-lang">${lang}</span><button class="copy-btn" onclick="navigator.clipboard.writeText(this.closest('.code-block').querySelector('code').textContent)">Copy</button></div><pre><code class="hljs language-${lang}">`,
    )
    .replace(
      /<pre><code class="hljs">/g,
      '<div class="code-block"><div class="code-header"><span class="code-lang"></span><button class="copy-btn" onclick="navigator.clipboard.writeText(this.closest(\'.code-block\').querySelector(\'code\').textContent)">Copy</button></div><pre><code class="hljs">',
    )
    .replace(/<\/code><\/pre>/g, '</code></pre></div>');
}

function renderMd(text: string): string {
  return addCodeChrome(marked.parse(preprocessMd(text)) as string);
}

function extractFit(attrs: Attrs): { fit: string | null; rest: Attrs } {
  const { fit: _f, hfit: _h, vfit: _v, ...rest } = attrs;
  const mode = _f === true ? 'both' : _h === true ? 'h' : _v === true ? 'v' : null;
  return { fit: mode, rest };
}
---

{nodes.map((node) => {
  if (node.kind === 'markdown') {
    return <div class="md" set:html={renderMd(node.text)} />;
  }
  if (node.kind === 'row') {
    const { fit, rest } = extractFit(node.attrs);
    const style = `display:flex;flex-direction:row;gap:var(--slide-gap-row);align-items:center;justify-content:center;${attrsToStyle(rest)}`;
    return (
      <div style={style} {...(fit ? { 'data-fit': fit } : {})}>
        <Astro.self nodes={node.children} />
      </div>
    );
  }
  if (node.kind === 'col') {
    const { fit, rest } = extractFit(node.attrs);
    const style = `display:flex;flex-direction:column;gap:var(--slide-gap-col);align-items:center;justify-content:center;${attrsToStyle(rest)}`;
    return (
      <div style={style} {...(fit ? { 'data-fit': fit } : {})}>
        <Astro.self nodes={node.children} />
      </div>
    );
  }
  if (node.kind === 'block') {
    const { fit, rest } = extractFit(node.attrs);
    const style = attrsToStyle(rest);
    return (
      <div style={style} {...(fit ? { 'data-fit': fit } : {})}>
        <Astro.self nodes={node.children} />
      </div>
    );
  }
  return null;
})}
