---
import type { AssetRef } from '../../lib/parser';
import OptimizedImage from '../OptimizedImage.astro';

interface Props {
  asset: AssetRef;
}

const { asset } = Astro.props;
const blurPx = asset.attrs.blur ? Number(asset.attrs.blur) : 0;
---

<OptimizedImage
  class="slide-bg"
  asset={asset}
  extraStyle={`--blur-expand:${blurPx}px`}
/>

<style>
  .slide-bg {
    position: absolute;
    inset: calc(-1 * var(--blur-expand));
    width: calc(100% + 2 * var(--blur-expand));
    height: calc(100% + 2 * var(--blur-expand));
    pointer-events: none;
  }
</style>
