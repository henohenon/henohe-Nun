---
import type { AssetRef } from '../../lib/parser';
import OptimizedImage from '../OptimizedImage.astro';

interface Props {
  asset: AssetRef;
}

const { asset } = Astro.props;
const blurPx = asset.attrs.blur ? Number(asset.attrs.blur) : 0;
const expand = blurPx ? `calc(100% + ${2 * blurPx}px)` : '100%';
const inset = blurPx ? `-${blurPx}px` : '0';
---

<OptimizedImage
  class="slide-bg"
  asset={asset}
  extraStyle={`position:absolute;inset:${inset};width:${expand};height:${expand};pointer-events:none`}
/>
