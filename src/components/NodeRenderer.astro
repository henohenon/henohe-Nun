---
import { marked } from 'marked';
import type { Node } from '../lib/parser';
import { attrsToStyle } from '../lib/parser';

interface Props {
  nodes: Node[];
}

const { nodes } = Astro.props;

marked.setOptions({ gfm: true, breaks: false });
---

{nodes.map((node) => {
  if (node.kind === 'markdown') {
    const html = marked.parse(node.text) as string;
    return <div class="md" set:html={html} />;
  }
  if (node.kind === 'row') {
    const style = `display:flex;flex-direction:row;gap:24px;align-items:center;justify-content:center;${attrsToStyle(node.attrs)}`;
    return (
      <div style={style}>
        <Astro.self nodes={node.children} />
      </div>
    );
  }
  if (node.kind === 'col') {
    const style = `display:flex;flex-direction:column;gap:16px;align-items:center;justify-content:center;${attrsToStyle(node.attrs)}`;
    return (
      <div style={style}>
        <Astro.self nodes={node.children} />
      </div>
    );
  }
  if (node.kind === 'txt') {
    return <span style={attrsToStyle(node.attrs)}>{node.text}</span>;
  }
  if (node.kind === 'img') {
    // Sizing rules (aspect ratio always preserved):
    //   w only  -> width=w, height auto
    //   h only  -> height=h, width auto
    //   w and h -> max-width/height caps, whichever is smaller wins (object-fit:contain)
    //   neither -> falls through to CSS default (.slide-body img: fit container)
    const { w, h, ...rest } = node.attrs;
    const pxVal = (v: unknown) =>
      typeof v === 'string' ? (/^-?\d+(\.\d+)?$/.test(v) ? `${v}px` : v) : undefined;
    const wv = pxVal(w);
    const hv = pxVal(h);
    let sizeStyle = '';
    if (wv && hv) sizeStyle = `max-width:${wv};max-height:${hv};width:auto;height:auto;object-fit:contain;`;
    else if (wv) sizeStyle = `width:${wv};height:auto;`;
    else if (hv) sizeStyle = `height:${hv};width:auto;`;
    return <img src={node.src} style={`${sizeStyle}${attrsToStyle(rest)}`} />;
  }
  return null;
})}
