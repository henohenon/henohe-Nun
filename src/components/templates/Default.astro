---
import Markup from '../slide/Markup.astro';

interface Props {
  heading: string;
  body: string;
}

const { heading, body } = Astro.props;
---

<div class="template-shell">
  {heading && <h2 class="slide-title">{heading}</h2>}
  <div class="slide-body body">
    <Markup body={body} />
  </div>
</div>

<style>
  .body {
    display: grid;
    grid-auto-rows: min-content;
    align-content: start;
    min-height: 0;
  }
</style>
