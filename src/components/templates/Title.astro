---
import type { Slide } from '../../lib/parser';

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;
const subtitle = slide.bodyLines[0] ?? '';
---

<div class="template-title">
  <img class="henoheno" src="/images/henoheno.svg" alt="" />
  <h1 class="title">{slide.heading}</h1>
  {subtitle && <p class="subtitle">{subtitle}</p>}
</div>

<style>
  .template-title {
    position: relative;
    width: 100%;
    height: 100%;
    background: #ffffff;
    overflow: hidden;
  }
  .henoheno {
    position: absolute;
    right: -80px;
    bottom: -40px;
    width: 1500px;
    height: auto;
    pointer-events: none;
  }
  .title {
    position: absolute;
    left: 140px;
    top: 480px;
    margin: 0;
    font-size: 176px;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: #0a0a0a;
    line-height: 1;
  }
  .subtitle {
    position: absolute;
    left: 148px;
    top: 700px;
    margin: 0;
    font-size: 52px;
    color: #6b6b6b;
    font-weight: 400;
    letter-spacing: 0.02em;
  }
</style>
