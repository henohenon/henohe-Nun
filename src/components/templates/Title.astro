---
import { marked } from 'marked';
import type { Slide } from '../../lib/parser';

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;
const subtitleRaw = slide.bodyLines[0] ?? '';
const subtitleHtml = subtitleRaw ? (marked.parseInline(subtitleRaw) as string) : '';
---

<div class="template-title">
  <img class="henoheno" src="/images/henoheno.svg" alt="" />
  <div class="text">
    <h1 class="title">{slide.heading}</h1>
    {subtitleHtml && <p class="subtitle" set:html={subtitleHtml} />}
  </div>
</div>

<style>
  .template-title {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 0 6vw;
    box-sizing: border-box;
  }
  .henoheno {
    position: absolute;
    right: calc(min(91vw, 143vh) * -0.13);
    bottom: calc(min(91vw, 143vh) * -0.75);
    width: min(95vw, 150vh);
    height: auto;
    pointer-events: none;
  }
  .text {
    position: relative;
    z-index: 1;
    max-width: 60%;
  }
  .title {
    margin: 0;
    font-size: clamp(36px, 11vmin, 200px);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: black;
    line-height: 1;
  }
  .subtitle {
    margin: clamp(12px, 2vmin, 32px) 0 0 0;
    font-size: clamp(16px, 3.2vmin, 60px);
    color: #3d3d3d;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  /* Subtitle bold: weight only, keep grey color (no theme color override). */
  .subtitle :global(strong),
  .subtitle :global(b) {
    color: inherit;
    font-weight: 900;
    -webkit-text-stroke: 0.035em currentColor;
  }
</style>
