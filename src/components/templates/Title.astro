---
import { Image } from 'astro:assets';
import henoheno from '../../assets/images/henoheno.svg';
import { renderInline } from '../../lib/markdown';

interface Props {
  heading: string;
  subtitle?: string;
}

const { heading, subtitle } = Astro.props;
const subtitleHtml = subtitle ? renderInline(subtitle) : '';
---

<div class="template-title">
  <Image class="henoheno" src={henoheno} alt="" />
  <div class="text">
    <h1 class="title">{heading}</h1>
    {subtitleHtml && <p class="subtitle" set:html={subtitleHtml} />}
  </div>
</div>

<style>
  .template-title {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    display: grid;
    align-content: center;
    padding: 0 6cqw;
    box-sizing: border-box;
  }
  .henoheno {
    position: absolute;
    right: calc(min(91cqw, 143cqh) * -0.13);
    bottom: calc(min(91cqw, 143cqh) * -0.75);
    width: min(95cqw, 150cqh);
    height: auto;
    pointer-events: none;
  }
  .text {
    position: relative;
    z-index: 1;
    max-width: 60%;
  }
  .title {
    margin: 0;
    font-size: clamp(36px, 11cqmin, 200px);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--strong);
    line-height: 1;
  }
  .subtitle {
    margin: clamp(12px, 2cqmin, 32px) 0 0 0;
    font-size: clamp(16px, 3.2cqmin, 60px);
    color: var(--fg-mid);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  /* Subtitle bold: weight only, keep grey color (no theme color override). */
  .subtitle :global(strong),
  .subtitle :global(b) {
    color: inherit;
    font-weight: 900;
    -webkit-text-stroke: 0.035em currentColor;
  }
</style>
