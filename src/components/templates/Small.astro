---
// Small template: centered small text, driven by the slide heading (`# text`).
interface Props {
  heading: string;
}

const { heading } = Astro.props;
---

<div class="template-small">
  <h2 class="text">{heading}</h2>
</div>

<style>
  .template-small {
    width: 100%;
    height: 100%;
    display: grid;
    place-content: center;
    padding: clamp(12px, 6cqmin, 120px);
    box-sizing: border-box;
  }
  .text {
    font-size: clamp(12px, calc(4.1cqmin + 4px), 88px);
    font-weight: 500;
    color: var(--brand);
    letter-spacing: 0.01em;
  }
</style>
