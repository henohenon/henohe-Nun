---
// Thx template: centered closing message, driven by the slide heading (`# text`).
import type { Slide } from '../../lib/parser';

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;
---

<div class="template-thx">
  <div class="text">{slide.heading}</div>
</div>

<style>
  .template-thx {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(24px, 6vmin, 180px);
    box-sizing: border-box;
  }
  .text {
    font-size: clamp(22px, calc(4.1vmin + 4px), 88px);
    font-weight: 500;
    color: var(--theme-color);
    letter-spacing: 0.01em;
  }
</style>
