---
import { marked } from 'marked';
import type { Slide } from '../../lib/parser';
import NodeRenderer from '../layers/NodeRenderer.astro';

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;
const subHtml = slide.subheading ? (marked.parseInline(slide.subheading) as string) : '';
---

<div class="template-note">
  <h2 class="slide-title">{slide.heading}</h2>
  <div class="slide-body body">
    <div class="body-center">
      <NodeRenderer nodes={slide.body} />
    </div>
    {subHtml && (
      <div class="body-bottom">
        <p set:html={subHtml} />
      </div>
    )}
  </div>
</div>

<style>
  .template-note {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: clamp(32px, 8cqmin, 180px) clamp(32px, 8cqmin, 180px) clamp(48px, 10cqmin, 200px);
    box-sizing: border-box;
  }
  .body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    text-align: center;
    line-height: 1.4;
    min-height: 0;
  }
  .body-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }
  .body-bottom {
    flex: 0 0 auto;
  }
</style>
