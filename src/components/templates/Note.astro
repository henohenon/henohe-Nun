---
import type { Slide } from '../../lib/parser';
import NodeRenderer from '../NodeRenderer.astro';

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;
// Split body: non-markdown nodes (txt/img/row/col) centered in the middle,
// plain markdown text pinned to the bottom.
const centerNodes = slide.body.filter((n) => n.kind !== 'markdown');
const bottomNodes = slide.body.filter((n) => n.kind === 'markdown');
---

<div class="template-note">
  <h2 class="slide-title">{slide.heading}</h2>
  <div class="slide-body body">
    <div class="body-center">
      <NodeRenderer nodes={centerNodes} />
    </div>
    {bottomNodes.length > 0 && (
      <div class="body-bottom">
        <NodeRenderer nodes={bottomNodes} />
      </div>
    )}
  </div>
</div>

<style>
  .template-note {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: clamp(32px, 8vmin, 180px) clamp(32px, 8vmin, 180px) clamp(48px, 10vmin, 200px);
    box-sizing: border-box;
  }
  .body {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    text-align: center;
    line-height: 1.4;
  }
  .body-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 0;
  }
  .body-bottom {
    flex: 0 0 auto;
  }
</style>
