---
import { renderInline } from '../../lib/markdown';
import type { Slide } from '../../lib/types';
import NodeRenderer from '../slide/NodeRenderer.astro';

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;
const subHtml = slide.subheading ? renderInline(slide.subheading) : '';
---

<div class="template-note">
  <h2 class="slide-title">{slide.heading}</h2>
  <div class="slide-body body">
    <div class="body-center">
      <NodeRenderer body={slide.body} />
    </div>
    {subHtml && (
      <div class="body-bottom">
        <p set:html={subHtml} />
      </div>
    )}
  </div>
</div>

<style>
  .template-note {
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-rows: auto 1fr;
    padding: var(--slide-pad-top) var(--slide-pad-x) var(--slide-pad-bottom);
    box-sizing: border-box;
  }
  .body {
    display: grid;
    grid-template-rows: 1fr auto;
    text-align: center;
    line-height: 1.4;
    min-height: 0;
  }
  .body-center {
    display: grid;
    grid-auto-rows: min-content;
    justify-items: center;
    align-content: center;
    min-height: 0;
  }
</style>
