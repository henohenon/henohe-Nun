---
import { renderMarkup } from '../../lib/markup';
import type { RowBlock } from '../../lib/parser';

interface Props {
  heading: string;
  blocks: RowBlock[];
  gap?: string;
}

const { heading, blocks, gap } = Astro.props;

// Render each block's markdown in parallel so any async work (OGP fetches,
// image optimization) inside one block doesn't stall the others.
const rendered = await Promise.all(blocks.map((b) => renderMarkup(b.body)));
---

<div class="template-row">
  {heading && <h2 class="slide-title">{heading}</h2>}
  <div class="slide-body blocks" style={gap ? `gap:${gap}` : undefined}>
    {blocks.map((block, i) => (
      <div class="row-block">
        {block.title && <h3 class="row-block-title">{block.title}</h3>}
        <Fragment set:html={rendered[i]} />
      </div>
    ))}
  </div>
</div>

<style>
  .template-row {
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-rows: auto 1fr;
    padding: var(--slide-pad-top) var(--slide-pad-x) var(--slide-pad-bottom);
    box-sizing: border-box;
  }
  .blocks {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(0, auto);
    gap: clamp(24px, 4cqmin, 96px);
    justify-content: center;
    align-items: start;
    min-height: 0;
    overflow: hidden;
  }
  .row-block {
    display: grid;
    grid-auto-rows: min-content;
    align-content: start;
    min-width: 0;
    min-height: 0;
  }
  .row-block-title {
    font-size: clamp(22px, 3.8cqmin, 80px);
    font-weight: 700;
    color: var(--theme-color);
    letter-spacing: -0.02em;
    margin: 0 0 0.35em 0;
    line-height: 1.2;
  }
</style>
