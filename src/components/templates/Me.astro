---
import type { Slide } from '../../lib/parser';
import OptimizedImage from '../OptimizedImage.astro';
import NodeRenderer from '../layers/NodeRenderer.astro';

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;
const iconAsset = slide.icon
  ? { src: slide.icon.src, attrs: slide.icon.attrs }
  : undefined;
---

<div class="template-me">
  <div class="left">
    {iconAsset && <OptimizedImage class="icon" asset={iconAsset} widths={[960]} />}
  </div>
  <div class="right">
    <div class="slide-body body">
      <NodeRenderer nodes={slide.body} />
    </div>
  </div>
  <h2 class="slide-title label">{slide.heading}</h2>
</div>

<style>
  .template-me {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    overflow: hidden;
  }
  .left {
    /* Sized by the icon + horizontal padding, not a fixed percentage. */
    flex: 0 0 auto;
    background: #ffffff;
    /* Top padding reserves space for the absolute-positioned heading so the icon
       centers between the heading's bottom and the slide's bottom. */
    padding:
      calc(var(--slide-pad-top) + var(--slide-title-size))
      clamp(40px, 7cqmin, 140px)
      var(--slide-pad-top);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  /* Title is pulled out of the white left column so it can span full width. */
  .label {
    position: absolute;
    top: var(--slide-pad-top);
    left: var(--slide-pad-x);
    right: var(--slide-pad-x);
    margin: 0;
    z-index: 2;
  }
  .icon {
    width: clamp(240px, 44cqmin, 840px);
    height: clamp(240px, 44cqmin, 840px);
    object-fit: cover;
    flex-shrink: 0;
    /* Horizontally centered in the white column, vertically between title and footer. */
    align-self: center;
    margin: auto 0;
  }
  .right {
    flex: 1;
    /* Top padding aligns text with where the body would start in other templates
       (template top padding + title height + title margin-bottom). */
    padding:
      calc(var(--slide-pad-top) + var(--slide-title-size))
      var(--slide-pad-x)
      var(--slide-pad-bottom);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }
  .body {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
</style>
