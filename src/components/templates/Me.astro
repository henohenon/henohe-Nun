---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { attrsToStyle } from '../../lib/style';
import type { Slide } from '../../lib/types';
import Markup from '../slide/Markup.astro';

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;

let iconUrl: string | undefined;
if (slide.icon) {
  const astroImages = import.meta.glob<{ default: ImageMetadata }>(
    '/src/assets/images/**/*.{png,jpg,jpeg,svg,gif,webp,avif}',
    { eager: true },
  );
  const matched = astroImages[`/src/assets/images${slide.icon.src}`];
  if (matched) {
    const optimized = await getImage({ src: matched.default, width: 960 });
    iconUrl = optimized.src;
  } else {
    iconUrl = slide.icon.src;
  }
}

const iconStyle = slide.icon
  ? [`background-image:url(${iconUrl})`, 'background-repeat:no-repeat', attrsToStyle(slide.icon.attrs)].join(';')
  : '';
---

<div class="template-me">
  <div class="left">
    {slide.icon && <div class="icon" style={iconStyle} />}
  </div>
  <div class="right">
    <div class="slide-body body">
      <Markup body={slide.body} />
    </div>
  </div>
  <h2 class="slide-title label">{slide.heading}</h2>
</div>

<style>
  .template-me {
    position: relative;
    width: 100%;
    height: 100%;
    display: grid;
    grid-template-columns: clamp(240px, 30%, 70cqh) 1fr;
    overflow: hidden;
  }
  .left {
    background: #ffffff;
    padding:
      calc(var(--slide-pad-top) + var(--slide-title-size))
      clamp(40px, 7cqmin, 140px)
      var(--slide-pad-top);
    box-sizing: border-box;
    display: grid;
    place-content: center;
  }
  .label {
    position: absolute;
    top: var(--slide-pad-top);
    left: var(--slide-pad-x);
    right: var(--slide-pad-x);
    margin: 0;
    z-index: 2;
  }
  .icon {
    width: clamp(160px, 20cqw, 400px);
    height: clamp(160px, 20cqw, 400px);
  }
  .right {
    padding:
      calc(var(--slide-pad-top) + var(--slide-title-size))
      var(--slide-pad-x)
      var(--slide-pad-bottom);
    box-sizing: border-box;
    display: grid;
    grid-auto-rows: min-content;
    align-content: start;
  }
  .body {
    display: grid;
    grid-auto-rows: min-content;
    align-content: start;
    min-height: 0;
  }
  /* Portrait: stack vertically */
  @container (orientation: portrait) {
    .template-me {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
    }
    .left {
      padding:
        calc(var(--slide-pad-top) + var(--slide-title-size) * 2)
        var(--slide-pad-x)
        0;
    }
    .icon {
      width: clamp(120px, 30cqw, 300px);
      height: clamp(80px, 25cqh, 200px);
    }
    .right {
      padding:
        0
        var(--slide-pad-x)
        var(--slide-pad-bottom);
    }
  }
</style>
