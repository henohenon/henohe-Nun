---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { attrsToCommon, attrsToObject } from '../../lib/style';
import type { AssetRef } from '../../lib/types';
import Markup from '../slide/Markup.astro';

interface Props {
  heading: string;
  body: string;
  icon?: AssetRef;
}

const { heading, body, icon } = Astro.props;

let iconUrl: string | undefined;
if (icon) {
  const astroImages = import.meta.glob<{ default: ImageMetadata }>(
    '/src/assets/images/**/*.{png,jpg,jpeg,svg,gif,webp,avif}',
    { eager: true },
  );
  const matched = astroImages[`/src/assets/images${icon.src}`];
  if (matched) {
    const optimized = await getImage({ src: matched.default, width: 960 });
    iconUrl = optimized.src;
  } else {
    iconUrl = icon.src;
  }
}

const iconStyle = icon ? [attrsToCommon(icon.attrs), attrsToObject(icon.attrs)].filter(Boolean).join(';') : '';
---

<div class="template-me">
  <div class="slide-body">
    <div class="left">
      {icon && <img class="icon" src={iconUrl} alt={heading} style={iconStyle} />}
    </div>
    <div class="right">
      <Markup body={body} />
    </div>
  </div>
  <h2 class="slide-title label">{heading}</h2>
</div>

<style>
  .template-me {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  .slide-body {
    display: grid;
    grid-template-columns: clamp(80px, 30%, 70cqh) 1fr;
    height: 100%;
  }
  .left {
    background: var(--base);
    padding:
      calc(var(--slide-pad-top) + var(--slide-title-size))
      clamp(16px, 7cqmin, 140px)
      var(--slide-pad-top);
    box-sizing: border-box;
    display: grid;
    place-content: center;
  }
  .label {
    position: absolute;
    top: var(--slide-pad-top);
    left: var(--slide-pad-x);
    right: var(--slide-pad-x);
    margin: 0;
    z-index: 2;
  }
  .icon {
    width: clamp(60px, 20cqw, 400px);
    height: clamp(60px, 20cqw, 400px);
  }
  .right {
    padding:
      calc(var(--slide-pad-top) + var(--slide-title-size))
      var(--slide-pad-x)
      var(--slide-pad-bottom);
    box-sizing: border-box;
    display: grid;
    grid-auto-rows: min-content;
    align-content: start;
  }
  /* Portrait: stack vertically */
  @container (orientation: portrait) {
    .slide-body {
      grid-template-columns: 1fr;
      grid-template-rows: auto 1fr;
    }
    .left {
      padding:
        calc(var(--slide-pad-top) + var(--slide-title-size) * 2)
        var(--slide-pad-x)
        0;
    }
    .icon {
      width: clamp(40px, 30cqw, 300px);
      height: clamp(30px, 25cqh, 200px);
    }
    .right {
      padding:
        0
        var(--slide-pad-x)
        var(--slide-pad-bottom);
    }
  }
</style>
