---
import type { Slide } from '../../lib/parser';

interface Props {
  slide: Slide;
}

const { slide } = Astro.props;
---

<div class="template-me">
  <div class="left">
    {slide.icon && <img class="icon" src={slide.icon} alt="" />}
  </div>
  <div class="right">
    <ul class="slide-body lines">
      {slide.bodyLines.map((line) => <li>{line}</li>)}
    </ul>
  </div>
  <h2 class="slide-title label">{slide.heading}</h2>
</div>

<style>
  .template-me {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    overflow: hidden;
  }
  .left {
    /* Sized by the icon + horizontal padding, not a fixed percentage. */
    flex: 0 0 auto;
    background: #ffffff;
    /* Top padding reserves space for the absolute-positioned heading so the icon
       centers between the heading's bottom and the slide's bottom. */
    padding:
      calc(clamp(32px, 8vmin, 180px) + clamp(42px, 9.1vmin, 182px))
      clamp(40px, 7vmin, 140px)
      clamp(32px, 8vmin, 180px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  /* Title is pulled out of the white left column so it can span full width. */
  .label {
    position: absolute;
    top: clamp(32px, 8vmin, 180px);
    left: clamp(32px, 8vmin, 180px);
    right: clamp(32px, 8vmin, 180px);
    margin: 0;
    z-index: 2;
  }
  .icon {
    width: clamp(240px, 44vmin, 840px);
    height: clamp(240px, 44vmin, 840px);
    object-fit: cover;
    flex-shrink: 0;
    /* Horizontally centered in the white column, vertically between title and footer. */
    align-self: center;
    margin: auto 0;
  }
  .right {
    flex: 1;
    /* Top padding aligns text with where the body would start in other templates
       (template top padding + title height + title margin-bottom). */
    padding:
      calc(clamp(32px, 8vmin, 180px) + clamp(42px, 9.1vmin, 182px) + clamp(20px, 4vmin, 80px))
      clamp(32px, 8vmin, 180px)
      clamp(48px, 10vmin, 200px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }
  /* Me has a flat list (no bullets) — override the shared bullet style. */
  .lines {
    padding: 0;
  }
  .lines li {
    margin: 0.1em 0;
    padding-left: 0;
  }
  .lines li::before {
    display: none;
  }
</style>
