---
interface Props {
  heading: string;
}

const { heading } = Astro.props;
---

<div class="template-big">
  <h2 class="text">{heading}</h2>
</div>

<style>
  .template-big {
    width: 100%;
    height: 100%;
    display: grid;
    place-content: center;
    padding: clamp(24px, 6cqmin, 180px);
    box-sizing: border-box;
  }
  .text {
    font-size: clamp(48px, 16cqmin, 320px);
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--theme-color);
    text-align: center;
    line-height: 0.95;
  }
</style>
