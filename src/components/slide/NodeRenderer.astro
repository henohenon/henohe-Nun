---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { renderMarkdown } from '../../lib/markdown';
import { fetchOgp, ogpToHtml } from '../../lib/ogp';
import { parseAttrs } from '../../lib/parser';
import { attrsToStyle } from '../../lib/style';

interface Props {
  body: string;
}

const { body } = Astro.props;

const astroImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/**/*.{png,jpg,jpeg,svg,gif,webp,avif}',
  { eager: true },
);

async function resolveUrl(src: string): Promise<string> {
  const matched = astroImages[`/src/assets/images${src}`];
  if (matched) {
    const optimized = await getImage({ src: matched.default, width: 1920 });
    return optimized.src;
  }
  return src;
}

const IMAGE_EXT = /\.(png|jpe?g|svg|gif|webp|avif)$/i;

// Process body line-by-line, skipping fenced code blocks.
const IMG_RE = /^@img(\s[^>]*)?>(.+)$/;
const LINK_RE = /^@link(\s[^>]*)?>(.+)$/;
const BRACKET_RE = /(?<!!)\[([^\]]+)\](?!\()/g;
const lines = body.split('\n');
const outLines: string[] = [];
let fenceMarker = '';
for (let line of lines) {
  const fenceMatch = /^(`{3,}|~{3,})/.exec(line.trim());
  const inFence = fenceMarker !== '';
  if (fenceMatch) {
    if (!inFence) {
      fenceMarker = fenceMatch[1];
    } else if (fenceMatch[1][0] === fenceMarker[0] && fenceMatch[1].length >= fenceMarker.length) {
      fenceMarker = '';
    }
  }
  if (inFence || fenceMatch) {
    outLines.push(line);
    continue;
  }
  // @img directive
  const imgMatch = IMG_RE.exec(line.trim());
  if (imgMatch) {
    const attrs = parseAttrs(imgMatch[1] ?? '');
    const src = imgMatch[2].trim();
    const url = await resolveUrl(src);
    const style = [
      `background-image:url(${url})`,
      'background-repeat:no-repeat',
      'width:100%',
      'min-height:200px',
      attrsToStyle(attrs),
    ].join(';');
    outLines.push(`<div style="${style}"></div>`);
    continue;
  }
  // @link directive
  const linkMatch = LINK_RE.exec(line.trim());
  if (linkMatch) {
    const attrs = parseAttrs(linkMatch[1] ?? '');
    const url = linkMatch[2].trim();
    const ogp = await fetchOgp(url);
    if (ogp) {
      outLines.push(ogpToHtml(ogp, attrs.v === true));
    } else {
      outLines.push(`<a href="${url}" target="_blank" rel="noopener">${url}</a>`);
    }
    continue;
  }
  // [path.png] image embeds
  for (const m of [...line.matchAll(BRACKET_RE)]) {
    const trimmed = m[1].trim();
    if (!IMAGE_EXT.test(trimmed)) continue;
    const url = await resolveUrl(trimmed);
    if (url !== trimmed) {
      line = line.replace(m[0], `![](${url})`);
    }
  }
  outLines.push(line);
}
const resolved = outLines.join('\n');
---

{resolved && <Fragment set:html={renderMarkdown(resolved)} />}
