---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { AssetRef } from '../../lib/types';

interface Props {
  asset: AssetRef;
  class?: string;
  extraStyle?: string;
  alt?: string;
  widths?: number[];
}

const { asset, class: className, extraStyle, alt = '', widths = [1920] } = Astro.props;
const astroImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/**/*.{png,jpg,jpeg,svg,gif,webp,avif}',
  { eager: true },
);
const astroImage = astroImages[`/src/assets/images${asset.src}`];
---

<div class={`image-wrap${className ? ` ${className}` : ''}`}>
  {astroImage ? (
    <Image
      class="image-base"
      style={extraStyle}
      src={astroImage.default}
      alt={alt}
      widths={widths}
      loading="eager"
    />
  ) : (
    <img
      class="image-base"
      style={extraStyle}
      src={asset.src}
      alt={alt}
    />
  )}
</div>

<style>
  .image-wrap {
    display: grid;
    width: 100%;
    height: 100%;
  }
  .image-base {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    place-self: center;
  }
</style>

