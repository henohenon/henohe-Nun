---
import { parseBody, parseFrame, parseNote, parseRow, parseTitle } from '../../lib/parser';
import type { GlobalMeta, SlideSource } from '../../lib/types';
import Big from '../templates/Big.astro';
import Default from '../templates/Default.astro';
import Me from '../templates/Me.astro';
import Note from '../templates/Note.astro';
import Row from '../templates/Row.astro';
import Small from '../templates/Small.astro';
import Title from '../templates/Title.astro';
import BgLayer from './BgLayer.astro';
import FooterLayer from './FooterLayer.astro';

interface Props {
  source: SlideSource;
  index: number;
  globalMeta: GlobalMeta;
}

const { source, index, globalMeta } = Astro.props;
const frame = parseFrame(source, index);

// Inherit per-slide fields from globalMeta when not set locally.
const bg = frame.bg ?? globalMeta.bg;
const fbg = frame.fbg ?? globalMeta.fbg;
let fr = frame.fr ?? globalMeta.fr;
let fl = frame.fl ?? globalMeta.fl;

// Title template: date auto-fills the footer-right; footer-left is forced
// empty so it doesn't inherit from globalFl.
if (source.template === 'title') {
  if (!frame.fr && globalMeta.date) fr = { text: globalMeta.date, attrs: {} };
  if (!frame.fl) fl = { text: '', attrs: {} };
}

// On title slides with no explicit bg, fall back to the fbg image so the
// footer mask and the hero background reuse the same asset.
const effectiveBg = bg ?? (source.template === 'title' ? fbg : undefined);

// Merge deck-wide + per-slide color overrides into inline CSS custom properties.
// Per-slide entries take precedence over deck-wide ones.
const mergedColors = { ...globalMeta.colors, ...frame.colors };
const colorStyle = Object.entries(mergedColors)
  .map(([k, v]) => `--${k}:${v}`)
  .join(';');
const theme = frame.theme ?? globalMeta.theme;
---

<section class="slide" data-index={index} data-theme={theme} style={colorStyle || undefined}>
  {effectiveBg && <BgLayer asset={effectiveBg} />}

  <div class="slide-inner">
    {source.template === 'title' && <Title heading={frame.heading} {...parseTitle(frame)} />}
    {source.template === 'me' && <Me heading={frame.heading} icon={frame.icon} {...parseBody(frame)} />}
    {source.template === 'default' && <Default heading={frame.heading} {...parseBody(frame)} />}
    {source.template === 'big' && <Big heading={frame.heading} />}
    {source.template === 'small' && <Small heading={frame.heading} />}
    {source.template === 'note' && <Note heading={frame.heading} {...parseNote(frame)} />}
    {source.template === 'row' && <Row heading={frame.heading} {...parseRow(frame)} />}
  </div>

  <FooterLayer fl={fl} fr={fr} fbg={fbg} slideIndex={index} />
</section>

<style>
  .slide {
    position: absolute;
    inset: 0;
    container-type: size;
    background-color: var(--base);
    color: var(--main);
    font-family: var(--font-body);
    overflow: hidden;
    /* Layout spacing (shared across templates) */
    --slide-pad-x: clamp(32px, 8cqmin, 180px);
    --slide-pad-top: clamp(32px, 8cqmin, 180px);
    --slide-pad-bottom: clamp(48px, 10cqmin, 200px);
    --slide-title-size: clamp(42px, 9.1cqmin, 182px);
    /* Footer */
    --footer-line-height: clamp(16px, 1.2cqmin, 28px);
    --footer-font-size: clamp(21px, 2.7cqmin, 63px);
    --footer-pad-x: clamp(24px, 4cqmin, 88px);
    --footer-text-nudge: clamp(-22px, calc(-1cqmin - 2px), -8px);
  }
  .slide-inner {
    position: absolute;
    inset: 0;
  }
</style>
