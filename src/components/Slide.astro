---
import type { Slide } from '../lib/parser';
import Title from './templates/Title.astro';
import Me from './templates/Me.astro';
import Default from './templates/Default.astro';
import Big from './templates/Big.astro';
import Thx from './templates/Thx.astro';
import Note from './templates/Note.astro';

interface Props {
  slide: Slide;
  fr?: string;
  fl?: string;
}

const { slide, fr, fl } = Astro.props;

const templateMap = {
  title: Title,
  me: Me,
  default: Default,
  big: Big,
  thx: Thx,
  note: Note,
} as const;

const Template = templateMap[slide.template as keyof typeof templateMap] ?? Default;

const bgStyle = slide.bg
  ? `background-image:url('${slide.bg}');background-size:cover;background-position:center;`
  : '';
---

<section class="slide" data-index={slide.index} style={bgStyle}>
  <div class="slide-inner">
    <Template slide={slide} />
  </div>
  {(fl || fr) && (
    <footer class="slide-footer">
      <span class="fl">{fl ?? ''}</span>
      <span class="fr">{fr ?? ''}</span>
    </footer>
  )}
</section>

<style>
  .slide {
    position: absolute;
    inset: 0;
    width: 1920px;
    height: 1080px;
    background-color: #ffffff;
    color: #0a0a0a;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Hiragino Kaku Gothic ProN', 'Yu Gothic', 'Meiryo', sans-serif;
    overflow: hidden;
  }
  .slide-inner {
    position: absolute;
    inset: 0;
  }
  .slide-footer {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    justify-content: space-between;
    padding: 40px 72px;
    font-size: 32px;
    font-weight: 700;
    color: #0a0a0a;
    pointer-events: none;
  }
</style>
