---
import type { Slide } from '../lib/parser';
import BgLayer from './layers/BgLayer.astro';
import FooterLayer from './layers/FooterLayer.astro';
import Title from './templates/Title.astro';
import Me from './templates/Me.astro';
import Default from './templates/Default.astro';
import Big from './templates/Big.astro';
import Thx from './templates/Thx.astro';
import Note from './templates/Note.astro';

interface Props {
  slide: Slide;
  date?: string;
}

const { slide, date } = Astro.props;

// Title template: use deck-level date as fr, blank fl.
const fr = slide.template === 'title' && date
  ? { text: date, attrs: {} }
  : slide.fr;
const fl = slide.template === 'title' && date
  ? undefined
  : slide.fl;

// f-bg is always effective as the footer-shaped mask. On title slides, if there's
// no explicit bg, the f-bg image is additionally used as the regular bg.
const effectiveFbg = slide.fbg;
const effectiveBg = slide.bg ?? (slide.template === 'title' ? slide.fbg : undefined);

const templateMap = {
  title: Title,
  me: Me,
  default: Default,
  big: Big,
  thx: Thx,
  note: Note,
} as const;
const Template = templateMap[slide.template as keyof typeof templateMap] ?? Default;
---

<section
  class="slide"
  data-index={slide.index}
>
  {effectiveBg && <BgLayer asset={effectiveBg} />}

  <div class="slide-inner">
    <Template slide={slide} />
  </div>

  <FooterLayer fl={fl} fr={fr} fbg={effectiveFbg} slideIndex={slide.index} />
</section>

<style>
  .slide {
    position: absolute;
    inset: 0;
    container-type: size;
    background-color: #ffffff;
    color: #0a0a0a;
    font-family: 'IBM Plex Sans JP', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Hiragino Kaku Gothic ProN', 'Yu Gothic', 'Meiryo', sans-serif;
    overflow: hidden;
    --footer-line-height: clamp(16px, 1.2cqmin, 28px);
    --footer-font-size: clamp(21px, 2.7cqmin, 63px);
    --footer-pad-x: clamp(24px, 4cqmin, 88px);
    --footer-text-nudge: clamp(-22px, calc(-1cqmin - 2px), -8px);
  }
  .slide-inner {
    position: absolute;
    inset: 0;
  }
</style>
